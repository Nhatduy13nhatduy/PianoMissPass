POSTGRES_DB=PianoMissPassDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=PianoMissPassDb;Username=postgres;Password=your_password_here
Jwt__Issuer=PianoMissPass
Jwt__Audience=PianoMissPass.Client
Jwt__Secret=your_long_random_secret_here
Jwt__ExpiresInMinutes=60

Email__From=no-reply@example.com
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__SmtpUser=your_smtp_user
Email__SmtpPass=your_smtp_password_or_app_password
